#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════╗
# ║  pomodoro.sh — i3/X11 Pomodoro Timer                        ║
# ║  Deps: bash, python3 (stdlib), libnotify, i3                ║
# ║  Optional: paplay (pulseaudio-utils)                         ║
# ╚══════════════════════════════════════════════════════════════╝
set -euo pipefail

# ─── defaults ─────────────────────────────────────────────────
WORK_MINS=1
SHORT_BREAK_MINS=5
LONG_BREAK_MINS=15
CYCLES=4
DAEMON=false
SOUND=""
LOG_FILE="$HOME/dev/pomodoro-log.csv"
PID_FILE="/tmp/pomodoro.pid"

# ─── usage ────────────────────────────────────────────────────
usage() {
  cat <<EOF

  🍅 pomodoro.sh — configurable pomodoro timer for i3/X11

  Usage: pomodoro [OPTIONS]

  Options:
    -w <mins>   Work duration            (default: 25)
    -s <mins>   Short break duration     (default: 5)
    -l <mins>   Long break duration      (default: 15)
    -c <n>      Cycles before long break (default: 4)
    -a <file>   Sound file via paplay    (optional)
    -d          Run as background daemon
    -h          Show this help

  Examples:
    pomodoro                    # 25/5 default
    pomodoro -w 50 -s 10       # 50min work, 10min break
    pomodoro -d -w 30          # daemon mode, 30min sessions

  Daemon control:
    kill \$(cat /tmp/pomodoro.pid)   # stop daemon
    tail -f /tmp/pomodoro.log        # follow daemon log

EOF
  exit 0
}

# ─── arg parsing ──────────────────────────────────────────────
while getopts "w:s:l:c:a:dh" opt; do
  case $opt in
    w) WORK_MINS="$OPTARG"        ;;
    s) SHORT_BREAK_MINS="$OPTARG" ;;
    l) LONG_BREAK_MINS="$OPTARG"  ;;
    c) CYCLES="$OPTARG"           ;;
    a) SOUND="$OPTARG"            ;;
    d) DAEMON=true                ;;
    h) usage                      ;;
    *) usage                      ;;
  esac
done

# ─── guard: daemon already running ────────────────────────────
if [[ -f "$PID_FILE" ]]; then
  OLD_PID=$(cat "$PID_FILE")
  if kill -0 "$OLD_PID" 2>/dev/null; then
    echo "⚠  Pomodoro daemon already running (PID: $OLD_PID)"
    echo "   Kill it first: kill $OLD_PID"
    exit 1
  else
    rm -f "$PID_FILE"
  fi
fi

# ─── ensure log exists with header ────────────────────────────
mkdir -p "$(dirname "$LOG_FILE")"
[[ -f "$LOG_FILE" ]] || printf "timestamp,type,duration_mins\n" > "$LOG_FILE"

# ─── red flash overlay (python3 + tkinter) ────────────────────
red_flash() {
  python3 - <<'PYEOF'
import tkinter as tk

root = tk.Tk()
root.attributes('-fullscreen', True)
root.attributes('-topmost', True)
root.configure(bg='red')
root.overrideredirect(True)
root.attributes('-alpha', 0.0)

counter = [0]
MAX_BLINKS = 6  # 3 on/off cycles

def blink():
    n = counter[0]
    if n >= MAX_BLINKS:
        root.destroy()
        return
    alpha = 0.45 if (n % 2 == 0) else 0.0
    root.attributes('-alpha', alpha)
    counter[0] += 1
    root.after(380, blink)

root.after(80, blink)
root.mainloop()
PYEOF
}

# ─── notification ─────────────────────────────────────────────
notify_end() {
  local mode="$1"
  local msg
  case "$mode" in
    work)        msg="Focus session complete — take your break." ;;
    short_break) msg="Break over — time to lock back in."        ;;
    long_break)  msg="Long break done — ready for the next round." ;;
  esac

  notify-send -u critical "🍅 Pomodoro" "$msg"

  [[ -n "$SOUND" && -f "$SOUND" ]] && paplay "$SOUND" &

  red_flash &
}

# ─── log entry ────────────────────────────────────────────────
log_session() {
  local type="$1"
  local duration="$2"
  printf "%s,%s,%s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$type" "$duration" \
    >> "$LOG_FILE"
}

# ─── TUI countdown ────────────────────────────────────────────
countdown() {
  local mins="$1"
  local mode="$2"
  local session_num="$3"
  local total=$(( mins * 60 ))

  if $DAEMON; then
    sleep "$total"
    return
  fi

  local label color
  case "$mode" in
    work)
      label="FOCUS"
      color="\e[1;31m"
      ;;
    short_break)
      label="SHORT BREAK"
      color="\e[1;32m"
      ;;
    long_break)
      label="LONG BREAK"
      color="\e[1;33m"
      ;;
  esac

  while (( total > 0 )); do
    local m=$(( total / 60 ))
    local s=$(( total % 60 ))

    tput clear
    printf "\n"
    printf "  ${color}●  %s\e[0m" "$label"
    [[ "$mode" == "work" ]] && printf "   \e[2mSession #%d\e[0m" "$session_num"
    printf "\n\n"
    printf "  \e[1m%02d:%02d\e[0m\n" "$m" "$s"
    printf "\n"
    printf "  \e[2mwork %dm  ·  short %dm  ·  long %dm  ·  every %d cycles\e[0m\n" \
      "$WORK_MINS" "$SHORT_BREAK_MINS" "$LONG_BREAK_MINS" "$CYCLES"
    printf "\n"
    printf "  \e[2mCtrl+C to quit\e[0m\n"

    sleep 1
    total=$(( total - 1 ))
  done
}

# ─── cleanup on exit ─────────────────────────────────────────
cleanup() {
  if ! $DAEMON; then
    tput cnorm
    tput clear
    printf "  Pomodoro stopped.\n"
  fi
  rm -f "$PID_FILE"
  exit 0
}

trap cleanup INT TERM

# ─── core loop ────────────────────────────────────────────────
run() {
  local session=1
  local cycle=1

  while true; do
    countdown "$WORK_MINS" "work" "$session"
    log_session "work" "$WORK_MINS"
    notify_end "work"

    if (( cycle % CYCLES == 0 )); then
      countdown "$LONG_BREAK_MINS" "long_break" "$session"
      log_session "long_break" "$LONG_BREAK_MINS"
      notify_end "long_break"
    else
      countdown "$SHORT_BREAK_MINS" "short_break" "$session"
      log_session "short_break" "$SHORT_BREAK_MINS"
      notify_end "short_break"
    fi

    session=$(( session + 1 ))
    cycle=$(( cycle + 1 ))
  done
}

# ─── entry point ─────────────────────────────────────────────
if $DAEMON; then
  run >> /tmp/pomodoro.log 2>&1 &
  DAEMON_PID=$!
  echo "$DAEMON_PID" > "$PID_FILE"
  printf "🍅 Pomodoro daemon started (PID: %d)\n" "$DAEMON_PID"
  printf "   Log: tail -f /tmp/pomodoro.log\n"
  printf "   Stop: kill %d\n" "$DAEMON_PID"
  disown "$DAEMON_PID"
  exit 0
fi

tput civis
run
