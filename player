#!/usr/bin/env bash
SIGNAL=9
MAX_LEN=22

case $BLOCK_BUTTON in
    1) playerctl play-pause; pkill -RTMIN+$SIGNAL i3blocks 2>/dev/null; exit ;;
    4) playerctl previous;   pkill -RTMIN+$SIGNAL i3blocks 2>/dev/null; exit ;;
    5) playerctl next;       pkill -RTMIN+$SIGNAL i3blocks 2>/dev/null; exit ;;
esac

STATUS=$(playerctl status 2>/dev/null) || exit 0

TITLE=$(playerctl metadata title 2>/dev/null)
[[ ${#TITLE} -gt $MAX_LEN ]] && TITLE="${TITLE:0:$MAX_LEN}…"

case $STATUS in
    Playing)
        ICON="󰐊"
        ;;
    Paused)
        ICON="󰏤"
        ;;
    *)
        exit 0
        ;;
esac

echo "<span foreground='#8fbcbb'>${ICON} ${TITLE}</span>"
