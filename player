#!/usr/bin/env bash

MAX_LEN=28

case $BLOCK_BUTTON in
    1) playerctl play-pause ;;
esac

status=$(playerctl status 2>/dev/null)

if [[ -z "$status" ]]; then
    echo "<span size='large'>㬚ｽｴ</span>"
    exit 0
fi

title=$(playerctl metadata title 2>/dev/null)

[[ ${#title} -gt $MAX_LEN ]] && title="${title:0:$MAX_LEN}窶ｦ"

icon="㬚商"
[[ "$status" == "Playing" ]] && icon="㬚肢"

echo "<span size='large'>${icon}</span>  <span>${title}</span>"
